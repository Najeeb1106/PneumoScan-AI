print("Unzipping dataset...")
!unzip -q chest-xray-pneumonia.zip

# Rename the folder to match our script's expectations if necessary
import os
if os.path.exists('chest_xray'):
    # The dataset usually unzips into 'chest_xray'
    # We can rename it to 'Radiography' or just update the script
    # Let's rename it to Radiography to stay consistent with pneumonia_detection.py
    os.rename('chest_xray', 'Radiography')
    print("Dataset ready in 'Radiography/' folder.")
else:
    print("Please check the unzipped folder name and update base_dir in pneumonia_detection.py")
